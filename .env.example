# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Spotify (used by the spotify-search Edge Function) ───────────────────────
# Create an app at https://developer.spotify.com/dashboard
# VITE_SPOTIFY_CLIENT_ID is not needed by the frontend — the client ID and
# secret are stored as Supabase Edge Function secrets:
#   npx supabase secrets set SPOTIFY_CLIENT_ID=xxx SPOTIFY_CLIENT_SECRET=yyy
