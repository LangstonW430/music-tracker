# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# The Client ID is used by Supabase Auth — add it in the Supabase Dashboard under
# Auth → Providers → Spotify.
# The Client Secret is stored ONLY as a Supabase Edge Function secret (never in .env):
#   supabase secrets set SPOTIFY_CLIENT_ID=xxx SPOTIFY_CLIENT_SECRET=yyy
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
